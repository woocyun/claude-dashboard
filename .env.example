# Copy this file to ".env" and fill in values as needed.
#   cp .env.example .env
#
# Every variable here is OPTIONAL — the dashboard runs with no config at all.
# (The local Claude Code usage panel works offline with zero setup.)

# Port the dashboard listens on. Default: 4317
PORT=4317

# Interface to bind. Default: 127.0.0.1 (localhost only).
# The dashboard has NO authentication — only set 0.0.0.0 (LAN-visible) on a
# network you trust.
HOST=127.0.0.1

# Organization Admin API key (starts with "sk-ant-admin...") to enable the
# optional org-level Usage & Cost panel.
#
#   - Get one from the Anthropic Console under an ORGANIZATION (Settings > API keys).
#   - This is ORG-ONLY: individual Pro/Max accounts cannot use the Admin API,
#     and the panel will simply stay disabled without it.
#   - Treat this like a password. NEVER commit your real .env file.
ANTHROPIC_ADMIN_KEY=
