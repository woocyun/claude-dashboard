# Copy this file to ".env" and fill in values as needed.
#   cp .env.example .env
#
# Everything here is OPTIONAL — the app runs with no config. A .env in the
# project root is loaded automatically when you launch the app.

# Port the embedded dashboard server listens on (localhost only). Default: 3000
PORT=3000

# Interface the embedded server binds to. Default: 127.0.0.1 (localhost only).
# The server has NO authentication — only set 0.0.0.0 (LAN-visible) on a network
# you trust.
HOST=127.0.0.1

# Override the claude.ai organization UUID used for the live "Subscription
# limits" card. Normally auto-detected from your signed-in session, so you can
# leave this empty; set it only if detection picks the wrong org. This is a
# plain identifier, NOT a secret.
CLAUDE_ORG_ID=
